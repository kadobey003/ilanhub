# Database (PostgreSQL + Drizzle)
DATABASE_URL=postgresql://ilanhub:secret@localhost:5432/ilanhub

# Redis
REDIS_URL=redis://localhost:6450

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Auth
JWT_SECRET=change-me
ADMIN_EMAIL=admin@ilanhub.local
ADMIN_PASSWORD=admin123
DEV_LOGIN_PHONE=+380000000001
PUBLIC_URL=https://dev.ilanhub.com

# Web SEO
NEXT_PUBLIC_SITE_URL=https://ilanhub.com
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ilanhub_bot

# Cloudflare Tunnel (opsiyonel — webhook SSL için)
# Hızlı dev: scripts/cloudflare-tunnel.ps1 → trycloudflare URL'sini PUBLIC_URL yap
# Kalıcı: Zero Trust > Tunnels > token → CLOUDFLARE_TUNNEL_TOKEN
CLOUDFLARE_TUNNEL_TOKEN=

# Bots
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=ilanhub_bot
# Admin moderation group (notifications + /onayla commands)
TELEGRAM_ADMIN_CHAT_ID=-5483319216
# Optional: allow admin commands in DM (comma-separated Telegram user IDs)
TELEGRAM_ADMIN_USER_IDS=
# Portmone provider token from @BotFather → Bot Settings → Payments → Portmone
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
BOT_INTERNAL_SECRET=dev-bot-secret
VIBER_AUTH_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=ilanhub

# Horeca bot addons (UAH)
HORECA_PIN_PRICE=500
HORECA_DAILY_DUPLICATE_PRICE=150
HORECA_PIN_RESERVE_NOTE=
# Logo watermark on Horeca photos (worker). Set false to disable.
HORECA_WATERMARK=true
# Default: packages/watermark/assets/logo.png (UAREKLAMHUB)
HORECA_LOGO_PATH=

# API (lokal dev: web/admin :3010; Docker: :3000)
PORT=3010
API_URL=http://localhost:3010

# Meta (Instagram yayın + WhatsApp)
META_APP_ID=
META_APP_SECRET=

# Ödeme (Ukrayna)
MONOPAY_TOKEN=
MONOPAY_WEBHOOK_SECRET=
PORTMONE_PAYEE_ID=
PORTMONE_LOGIN=
PORTMONE_PASSWORD=
PORTMONE_SIGNATURE_KEY=
BANK_TRANSFER_IBAN=
BANK_TRANSFER_RECIPIENT=

# Lokalizasyon
DEFAULT_LOCALE=uk
DEFAULT_CURRENCY=UAH
